{
  "name": "nmr-metadata",
  "version": "4.0.0",
  "description": "Extract and normalize metadata from NMR spectra",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "keywords": [],
  "author": "Michaël Zasso",
  "repository": "cheminfo/nmr-metadata",
  "bugs": {
    "url": "https://github.com/cheminfo/nmr-metadata/issues"
  },
  "homepage": "https://github.com/cheminfo/nmr-metadata",
  "license": "MIT",
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "jcampconverter": "^12.2.1",
    "nmr-processing": "^22.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@zakodium/tsconfig": "^1.0.2",
    "eslint": "^9.24.0",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
